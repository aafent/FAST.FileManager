{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      /*
        ── S3 HTTP diagnostics ───────────────────────────────────────────────
        Debug → logs every request method + URL + response status code.
        Trace → also logs all request/response headers and a .http snippet
                you can paste into VS / Rider / VS Code REST Client to replay
                the exact signed request (valid within the 15-minute SigV4 window).

        Uncomment one of the lines below to enable:
      */
      // "FAST.FileManager.Providers.S3.S3Client": "Debug",
      "FAST.FileManager.Providers.S3.S3Client": "Trace"
    }
  },
  "AllowedHosts": "*",

  /*
    ── S3 / Cloudflare R2 Configuration ─────────────────────────────────────
    Credentials live here on the SERVER — never sent to the browser.

    Single S3 instance (default section "S3"):
    ─────────────────────────────────────────
    providers.AddS3Provider(config, alias: "r2");

    Multiple S3 instances — use named subsections:
    ───────────────────────────────────────────────
    providers.AddS3Provider(config, alias: "r2",    sectionName: "S3:R2");
    providers.AddS3Provider(config, alias: "minio", sectionName: "S3:MinIO");

    appsettings.json for multiple instances:
    {
      "S3": {
        "R2":    { "Endpoint": "https://...", "Region": "auto",      "AccessKey": "...", "SecretKey": "...", "Buckets": ["my-bucket"] },
        "MinIO": { "Endpoint": "http://...",  "Region": "us-east-1", "AccessKey": "...", "SecretKey": "..." }
      }
    }
    ─────────────────────────────────────────────────────────────────────── */

